# Default deterministic mode works without provider keys.
COURSE_AGENT_MODE=fake

# OpenAI / ChatGPT mode
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Legacy Claude variables are unused by the product path, but the old client remains in the codebase for reference.
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-opus-4-8

# Local single-origin setting.
FRONTEND_ORIGIN=http://localhost:5175

# Production multi-origin CORS setting. Use * only during first deployment/bootstrap.
# FRONTEND_ORIGINS=https://your-vercel-app.vercel.app,https://your-custom-domain.com

# Container/cloud platforms usually provide PORT. The backend defaults to 8081 locally.
PORT=8081
